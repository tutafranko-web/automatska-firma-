{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs pre-bash",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs pre-edit",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs post-edit",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs post-bash",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs route",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs session-restore",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/auto-memory-hook.mjs import",
            "timeout": 8000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs session-end",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/auto-memory-hook.mjs sync",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs compact-manual"
          },
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs session-end",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs compact-auto"
          },
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs session-end",
            "timeout": 6000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs status",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs post-task",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmd /c node %CLAUDE_PROJECT_DIR%/.claude/helpers/hook-handler.cjs notify",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'exec node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/statusline.cjs\"'"
  },
  "permissions": {
    "allow": [
      "Bash(npx @claude-flow*)",
      "Bash(npx claude-flow*)",
      "Bash(node .claude/*)",
      "mcp__claude-flow__:*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: claude-flow <ruv@ruv.net>",
    "pr": "🤖 Generated with [claude-flow](https://github.com/ruvnet/claude-flow)"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_FLOW_V3_ENABLED": "true",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true"
  },
  "claudeFlow": {
    "version": "3.0.0",
    "enabled": true,
    "platform": {
      "os": "windows",
      "arch": "x64",
      "shell": "powershell"
    },
    "modelPreferences": {
      "default": "claude-opus-4-6",
      "routing": "claude-haiku-4-5-20251001"
    },
    "agentTeams": {
      "enabled": true,
      "teammateMode": "auto",
      "taskListEnabled": true,
      "mailboxEnabled": true,
      "coordination": {
        "autoAssignOnIdle": true,
        "trainPatternsOnComplete": true,
        "notifyLeadOnComplete": true,
        "sharedMemoryNamespace": "agent-teams"
      },
      "hooks": {
        "teammateIdle": {
          "enabled": true,
          "autoAssign": true,
          "checkTaskList": true
        },
        "taskCompleted": {
          "enabled": true,
          "trainPatterns": true,
          "notifyLead": true
        }
      }
    },
    "swarm": {
      "topology": "hierarchical-mesh",
      "maxAgents": 15,
      "autoSpawn": true
    },
    "marketing": {
      "enabled": true,
      "autopilot": true,
      "queen": "marketing-coordinator",
      "workers": [
        "content-strategist",
        "seo-specialist",
        "outbound-specialist",
        "conversion-optimizer",
        "sales-intelligence",
        "social-media-manager"
      ],
      "consensus": "weighted",
      "cycles": {
        "daily": {
          "agents": ["outbound-specialist", "social-media-manager", "content-strategist"],
          "tasks": [
            "Check outbound campaign metrics, adjust sequences with low open rates",
            "Publish scheduled social media content across all platforms",
            "Score and publish any pending content pieces"
          ]
        },
        "weekly": {
          "agents": ["seo-specialist", "conversion-optimizer", "marketing-coordinator"],
          "tasks": [
            "Run keyword gap analysis and update content attack briefs",
            "CRO audit on highest-traffic landing pages",
            "Weekly KPI review and agent task reallocation"
          ]
        },
        "biweekly": {
          "agents": ["sales-intelligence"],
          "tasks": [
            "Update competitive matrix and pricing intelligence",
            "Generate revenue attribution report",
            "Refresh ICP data and buying signals"
          ]
        },
        "monthly": {
          "agents": ["marketing-coordinator", "sales-intelligence", "content-strategist"],
          "tasks": [
            "Full marketing performance review",
            "Content calendar planning for next month",
            "Pipeline health analysis and forecast"
          ]
        }
      }
    },
    "memory": {
      "backend": "hybrid",
      "enableHNSW": true,
      "learningBridge": {
        "enabled": true
      },
      "memoryGraph": {
        "enabled": true
      },
      "agentScopes": {
        "enabled": true
      }
    },
    "neural": {
      "enabled": true
    },
    "daemon": {
      "autoStart": true,
      "workers": [
        "map",
        "audit",
        "optimize",
        "content-publish",
        "seo-optimize",
        "outbound-send",
        "cro-implement",
        "sales-brief",
        "social-publish",
        "campaign-report"
      ],
      "schedules": {
        "audit": {
          "interval": "4h",
          "priority": "critical"
        },
        "optimize": {
          "interval": "2h",
          "priority": "high"
        },
        "content-publish": {
          "interval": "24h",
          "priority": "high",
          "description": "Daily content production and publishing cycle"
        },
        "seo-optimize": {
          "interval": "168h",
          "priority": "high",
          "description": "Weekly SEO keyword research and optimization"
        },
        "outbound-send": {
          "interval": "24h",
          "priority": "critical",
          "description": "Daily outbound campaign execution and monitoring"
        },
        "cro-implement": {
          "interval": "168h",
          "priority": "high",
          "description": "Weekly CRO audit and landing page optimization"
        },
        "sales-brief": {
          "interval": "72h",
          "priority": "critical",
          "description": "Bi-weekly competitive intelligence and sales enablement update"
        },
        "social-publish": {
          "interval": "8h",
          "priority": "medium",
          "description": "3x daily social media content distribution"
        },
        "campaign-report": {
          "interval": "168h",
          "priority": "high",
          "description": "Weekly marketing KPI report and optimization"
        }
      }
    },
    "learning": {
      "enabled": true,
      "autoTrain": true,
      "patterns": [
        "coordination",
        "optimization",
        "prediction"
      ],
      "retention": {
        "shortTerm": "24h",
        "longTerm": "30d"
      }
    },
    "adr": {
      "autoGenerate": true,
      "directory": "/docs/adr",
      "template": "madr"
    },
    "ddd": {
      "trackDomains": true,
      "validateBoundedContexts": true,
      "directory": "/docs/ddd"
    },
    "security": {
      "autoScan": true,
      "scanOnEdit": true,
      "cveCheck": true,
      "threatModel": true
    }
  }
}